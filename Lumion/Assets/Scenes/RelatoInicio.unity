  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "imagina un reino de luz suave, donde las almas descansaban tras su paso
    por el mundo de los vivos. No era el cielo tradicional, sino un \"Lugar de Paso\",
    un jard\xEDn de recuerdos y paz donde la esencia de cada ser, su L\xFAmen, brillaba
    con un tono \xFAnico. El L\xFAmen no era solo energ\xEDa vital, era la suma de
    sus alegr\xEDas, sus amores, sus aprendizajes... su identidad. Con su L\xFAmen
    intacto, las almas pod\xEDan, eventualmente, trascender al verdadero Gran M\xE1s
    All\xE1. "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
